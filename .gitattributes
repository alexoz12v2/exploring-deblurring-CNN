# Python: Source files
# ============
*.pxd    text diff=python
*.py     text diff=python eol=lf
*.py3    text diff=python
*.pyw    text diff=python
*.pyx    text diff=python
*.pyz    text diff=python
*.pyi    text diff=python eol=lf

# Python: Binary files
# ============
*.db     binary
*.p      binary
*.pkl    binary 
*.pickle binary
*.pyc    binary export-ignore
*.pyo    binary export-ignore
*.pyd    binary

# Python: Jupyter notebook
*.ipynb  text eol=lf

# LaTex: Source Files
*.tex     text diff=tex
*.bib     text diff=tex
*.cls     text diff=tex
*.sty     text diff=tex

# LaTex: Binary Files (should be ignored)
*.aux     binary
*.log     binary
*.out     binary
*.toc     binary
*.fls     binary
*.fdb_latexmk binary


